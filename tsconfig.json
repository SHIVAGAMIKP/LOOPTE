{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["tests/**/*.ts", "Pages/**/*.ts", "support/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
